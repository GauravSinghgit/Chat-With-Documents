# ── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# No default — startup fails if unset. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true   # set to false in any real deployment (enables the Secure cookie flag)

# ── JWT ──────────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── CORS — comma-separated list of frontend origins allowed to send cookies ──
ALLOWED_ORIGINS=http://localhost:3000

# ── LLM ─────────────────────────────────────────────────────────────────────
MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7
MAX_RESPONSE_TOKENS=1024

# ── Database (Postgres + pgvector — also backs the document vector store) ──
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/ai_assistant
DOCUMENTS_PATH=./data/documents

# ── Features ─────────────────────────────────────────────────────────────────
PII_MASKING_ENABLED=true
ALLOWED_TOOLS=search_documents,get_conversation_history,search_web
TOP_K=5
